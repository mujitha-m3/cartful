<main>
  <div class="row">
    <div class="col-md-6">
      <img src="{{product.image}}" alt="{{product.name}}" class="img-fluid rounded shadow-sm" loading="lazy" />
    </div>
    <div class="col-md-6">
  <h1>{{product.name}}</h1>
  <p class="text-muted">{{product.category}}</p>
  <p class="lead">{{product.description}}</p>
  
  {{#if product.hasDiscount}}
    <p class="fw-bold h4 text-danger">{{product.price}} €</p>
    <p class="text-muted text-decoration-line-through small">{{product.original_price}} €</p>
    {{#if product.discount_type}}
      {{#if (eq product.discount_type "percentage")}}
        <p class="text-danger mb-1">-{{product.discount_value}}% Off</p>
      {{else if (eq product.discount_type "flat")}}
        <p class="text-danger mb-1">-{{product.discount_value}} € Off</p>
      {{/if}}
    {{/if}}
  {{else}}
    <p class="fw-bold h4">{{product.price}} €</p>
  {{/if}}

  {{#if (gt product.stock 0)}}
      <form method="POST" action="/cart/add" class="add-to-cart-form">
        <input type="hidden" name="product_id" value="{{product._id}}" />
        {{#if csrfToken}}
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        {{/if}}
        <div style="text-align: left !important; width: 100%; margin-top: 10px;">
          <button type="submit" class="btn btn-sm btn-success add-to-cart-button" style="width: auto; min-width: 120px;">
            Add to Cart
          </button>
        </div>
      </form>
      {{else}}
      <p class="text-danger fw-bold mt-3">Out of stock</p>
      {{/if}}
      <br />

      {{#if isInWishlist}}
      <form action="/wishlist/remove/{{product._id}}" method="POST" class="d-inline">
        <button type="submit" class="btn btn-sm btn-outline-danger" aria-label="Remove from wishlist">
          ❤️ In Wishlist
        </button>
      </form>
      {{else}}
      <form action="/wishlist/add/{{product._id}}" method="POST" class="d-inline">
        <button type="submit" class="btn btn-sm btn-outline-secondary" style="margin-top: -30px;" aria-label="Add to wishlist">
          🤍 Add to Wishlist
        </button>
      </form>
      {{/if}}
    </div>
  </div>

  <div class="row mt-5">
    <div class="col-md-12">
      {{> review-form}}
      <div id="reviews-container">
        {{> review-list}}
      </div>
    </div>
  </div>
</main>

<script src="/socket.io/socket.io.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Handle server-rendered flash messages
    const successMsg = "{{success_msg}}";
    const errorMsg = "{{error_msg}}";
    
    if (successMsg || errorMsg) {
      showToastNotification(successMsg || errorMsg, successMsg ? 'success' : 'error');
    }

    // Socket.io for reviews
    const socket = io();
    const productId = '{{product._id}}';

    socket.on('new-review', (data) => {
      if (data.productId === productId) {
        fetch(`/products/view/${productId}/reviews`)
          .then(response => response.text())
          .then(html => {
            document.getElementById('reviews-container').innerHTML = html;
          });
      }
    });

    // Add to cart form handling
    document.querySelectorAll('.add-to-cart-form').forEach(form => {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        const formData = new FormData(form);
        const product_id = formData.get('product_id');
        
        showToastNotification('Adding item to cart...', 'info');
        
        fetch('/cart/add', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ product_id })
        })
        .then(res => res.json())
        .then(data => {
          showToastNotification(data.message, data.success ? 'success' : 'error');
        })
        .catch(() => {
          showToastNotification('Failed to add item to cart', 'error');
        });
      });
    });

    // Wishlist form handling
    document.querySelectorAll('form[action^="/wishlist/"]').forEach(form => {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        const action = form.getAttribute('action');
        const method = form.getAttribute('method');
        
        showToastNotification('Processing...', 'info');
        
        fetch(action, {
          method: method,
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(Object.fromEntries(new FormData(form)))
        })
        .then(res => res.json())
        .then(data => {
          showToastNotification(data.message, data.success ? 'success' : 'error');
          if (data.success) {
            setTimeout(() => window.location.reload(), 1000);
          }
        })
        .catch(() => {
          showToastNotification('Operation failed', 'error');
        });
      });
    });

    // Helper function to show toast notifications
    function showToastNotification(message, type) {
      // Remove any existing notifications
      document.querySelectorAll('.toast-notification').forEach(el => el.remove());
      
      const colors = {
        success: '#28a745',
        error: '#dc3545',
        info: '#17a2b8'
      };
      
      const toast = document.createElement("div");
      toast.className = "toast-notification";
      toast.innerText = message;
      toast.style = `
        position: fixed;
        top: 20px;
        right: 20px;
        background-color: ${colors[type] || '#17a2b8'};
        color: #fff;
        padding: 12px 20px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        z-index: 1000;
        font-size: 14px;
        animation: slideIn 0.3s ease-out;
      `;
      
      document.body.appendChild(toast);
      
      setTimeout(() => {
        toast.style.animation = 'fadeOut 0.3s ease-out';
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }
  });
</script>

<style>
  @keyframes slideIn {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }
  
  @keyframes fadeOut {
    from { opacity: 1; }
    to { opacity: 0; }
  }
</style>