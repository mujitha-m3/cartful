<main>
    <div class="row">
        <div class="col-md-6">
            <img src="{{product.image}}" alt="{{product.name}}" class="img-fluid rounded shadow-sm" loading="lazy" />
        </div>
        <div class="col-md-6">
            <h1>{{product.name}}</h1>
            <p class="text-muted">{{product.category}}</p>
            <p class="lead">{{product.description}}</p>
            <p class="fw-bold h4">{{product.price}} €</p>

            {{#if (gt product.stock 0)}}
  <form action="/cart/add" method="POST" class="mt-3">
    <input type="hidden" name="productId" value="{{product._id}}">
    <button type="submit" class="btn btn-success">Add to Cart</button>
  </form>
{{else}}
  <p class="text-danger fw-bold mt-3">Out of stock</p>
{{/if}}
            <br />

            <!-- In your ProductDetails.handlebars, modify the wishlist section: -->
{{#if isInWishlist}}
  <form action="/wishlist/remove/{{product._id}}" method="POST" class="d-inline">
    <button type="submit" class="btn btn-sm btn-outline-danger" aria-label="Remove from wishlist">
      ❤️ In Wishlist
    </button>
  </form>
{{else}}
  <form action="/wishlist/add/{{product._id}}" method="POST" class="d-inline">
    <button type="submit" class="btn btn-sm btn-outline-secondary" aria-label="Add to wishlist">
      🤍 Add to Wishlist
    </button>
  </form>
{{/if}}

        </div>
    </div>
</main>