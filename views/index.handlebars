<h2>Welcome to the Cartful E-Commerce Platform</h2>
<p>Manage your products efficiently.</p>

<div style="display: flex; flex-wrap: wrap; gap: 20px;">
    {{#if success_msg}}
    <script>
        window.onload = function () {
            const toast = document.createElement("div");
            toast.innerText = "{{success_msg}}";
            toast.style.position = "fixed";
            toast.style.top = "20px";
            toast.style.right = "20px";
            toast.style.backgroundColor = "#28a745";
            toast.style.color = "#fff";
            toast.style.padding = "12px 20px";
            toast.style.borderRadius = "8px";
            toast.style.boxShadow = "0 2px 8px rgba(0,0,0,0.2)";
            toast.style.zIndex = 1000;
            toast.style.fontSize = "14px";
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.remove(); 
            }, 3000); // disappears in 3s
        };
    </script>
    {{/if}}


    {{#each products}}
    <div style="border: 1px solid #ccc; border-radius: 8px; padding: 16px; width: 200px;">
        <h3>{{this.name}}</h3>
        <p>€{{this.price}}</p>
        <p>{{this.description}}</p>
        <form method="POST" action="/cart/add">
            <input type="hidden" name="product_id" value="{{this._id}}" />
            <input type="number" name="quantity" value="1" min="1" />
            <button type="submit">Add to Cart</button>
        </form>
    </div>
    {{/each}}
</div>