<!-- Hero Section -->
<section class="hero-section text-center py-5">
  <div class="container">
    <h1 class="display-4">Welcome to Our Store</h1>
    <p class="lead mb-4">Discover amazing products at great prices</p>
    <a href="/products" class="btn btn-primary btn-lg">SHOP NOW</a>
  </div>
</section>

<!-- Categories Section -->
<section class="categories-section py-5">
  <div class="container">
    <h2 class="text-center mb-4">Browse Categories</h2>
    <div class="row">
      {{#each categories}}
      <div class="col-md-4 mb-4">
        <div class="card category-card h-100">
          <div class="card-body text-center">
            <h3 class="card-title">{{this.name}}</h3>
            <p class="card-text">Explore top items in {{this.name}} category</p>
            <a href="/categories/{{this._id}}" class="btn btn-outline-primary">View Products</a>
          </div>
        </div>
      </div>
      {{/each}}

      <!-- Example Cards (to be removed once real data is available) -->
      {{^categories}} <!-- Handlebars inverse block helper -->
      <div class="col-md-4 mb-4">
        <div class="card category-card h-100">
          <div class="card-body text-center">
            <h3 class="card-title">Electronics</h3>
            <p class="card-text">Explore top items in Electronics category</p>
            <a href="/categories/sample-id" class="btn btn-outline-primary">View Products</a>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card category-card h-100">
          <div class="card-body text-center">
            <h3 class="card-title">Fashion</h3>
            <p class="card-text">Explore top items in Fashion category</p>
            <a href="/categories/sample-id" class="btn btn-outline-primary">View Products</a>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card category-card h-100">
          <div class="card-body text-center">
            <h3 class="card-title">Home & Kitchen</h3>
            <p class="card-text">Explore top items in Home & Kitchen category</p>
            <a href="/categories/sample-id" class="btn btn-outline-primary">View Products</a>
          </div>
        </div>
      </div>
      {{/categories}}
    </div>
  </div>
</section>


<!-- Featured Products Section -->
<section class="products-section py-5 bg-light">
  <div class="container">
    <h2 class="text-center mb-4">Featured Products</h2>
    <div class="row">
      {{#each products}}
      <div class="col-md-4 mb-4">
        <div class="card product-card h-100">
          <div class="card-body text-center">
            <h3 class="card-title">{{this.name}}</h3>
            <p class="card-text">€{{this.price}}</p>
            <p class="card-text">{{this.description}}</p>
            <div class="d-flex justify-content-center gap-2 mt-3">
              <a href="/products/{{this._id}}" class="btn btn-outline-primary">View Details</a>
              <form method="POST" action="/cart/add" class="d-inline">
                <input type="hidden" name="product_id" value="{{this._id}}" />
                <button type="submit" class="btn btn-primary">Add to Cart</button>
              </form>
            </div>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
</section>


<!-- Newsletter Section -->
<section class="newsletter-section py-5">
  <div class="container text-center">
    <h2 class="mb-3">Subscribe to Our Newsletter</h2>
    <p class="mb-4">Stay updated with our latest products and offers</p>
    <form class="newsletter-form d-flex justify-content-center" action="/newsletter/subscribe" method="POST">
      <div class="input-group" style="max-width: 400px;">
        <input type="email" name="email" class="form-control" placeholder="Your email address" required>
        <button type="submit" class="btn btn-primary">Subscribe</button>
      </div>
    </form>
  </div>
</section>

{{#if success_msg}}
<script>
    window.onload = function () {
        const toast = document.createElement("div");
        toast.className = "toast-notification";
        toast.innerText = "{{success_msg}}";
        document.body.appendChild(toast);

        setTimeout(() => {
            toast.remove(); 
        }, 3000);
    };
</script>
{{/if}}