<div class="hero">
    <!-- Navigation inside hero -->
    <nav class="hero-nav">
        <div class="nav-container">
            <a class="nav-brand" href="/">Cartful</a>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/products">Products</a></li>
                <li><a href="/products/add-product">Add Product</a></li>
                <li><a href="/categories">Categories</a></li>
                <li><a href="/cart">Cart</a></li>
                <li><a href="/register">Member Registration</a></li>
                <li><a href="/profile">User Profile</a></li>
            </ul>
        </div>
    </nav>
    <h1>Welcome to Our Store</h1>
    <p>Discover amazing products at great prices</p>
    <a href="/products" class="cta-button">SHOP NOW</a>
</div>

<section class="categories">
    <h2>Browse Categories</h2>
    <div class="category-grid">
        {{#each categories}}
        <div class="category-card">
            <h3>{{this.name}}</h3>
            <a href="/categories/{{this._id}}" class="view-button">View Products</a>
        </div>
        {{/each}}
    </div>
</section>

<section class="products-section">
    <h2>Featured Products</h2>
    <div class="product-grid">
        {{#each products}}
        <div class="product-card">
            <h3>{{this.name}}</h3>
            <p>€{{this.price}}</p>
            <p>{{this.description}}</p>
            <a href="/products/{{this._id}}" class="view-button">View Details</a>
            <form method="POST" action="/cart/add" class="add-to-cart-form">
                <input type="hidden" name="product_id" value="{{this._id}}" />
                <div class="quantity-control">
                    <label for="quantity-{{this._id}}">Qty:</label>
                    <input type="number" id="quantity-{{this._id}}" name="quantity" value="1" min="1" />
                </div>
                <button type="submit" class="add-to-cart-btn">Add to Cart</button>
            </form>
        </div>
        {{/each}}
    </div>
</section>

<section class="newsletter">
    <h2>Subscribe to Our Newsletter</h2>
    <p>Stay updated with our latest products and offers</p>
    <form class="newsletter-form" action="/newsletter/subscribe" method="POST">
        <input type="email" name="email" placeholder="Your email address" required>
        <button type="submit">Subscribe</button>
    </form>
</section>

{{#if success_msg}}
<script>
    window.onload = function () {
        const toast = document.createElement("div");
        toast.className = "toast-notification";
        toast.innerText = "{{success_msg}}";
        document.body.appendChild(toast);

        setTimeout(() => {
            toast.remove(); 
        }, 3000);
    };
</script>
{{/if}}