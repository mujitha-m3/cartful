<!-- Hero Section -->
<section class="hero-section text-center py-5">
  <div class="container">
    <h1 class="display-4">Welcome to Our Store</h1>
    <p class="lead mb-4">Discover amazing products at great prices</p>
    <a href="/products" class="btn btn-primary btn-lg">SHOP NOW</a>
  </div>
</section>

<!-- Categories Section -->
<section class="categories-section py-5">
  <div class="container">
    <h2 class="text-center mb-4">Browse Categories</h2>
    <div class="row">
      {{#each categories}}
      <div class="col-md-4 mb-4">
        <div class="card category-card h-100">
          <div class="card-body text-center">
            <h3 class="card-title">{{this.name}}</h3>
            <p class="card-text">Explore top items in {{this.name}} category</p>
            <a href="/categories/{{this._id}}" class="btn btn-outline-primary">View Products</a>
          </div>
        </div>
      </div>
      {{/each}}

      {{^categories}}
      <div class="col-md-4 mb-4">
        <div class="card category-card h-100">
          <div class="card-body text-center">
            <h3 class="card-title">Electronics</h3>
            <p class="card-text">Explore top items in Electronics category</p>
            <a href="/categories/sample-id" class="btn btn-outline-primary">View Products</a>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card category-card h-100">
          <div class="card-body text-center">
            <h3 class="card-title">Fashion</h3>
            <p class="card-text">Explore top items in Fashion category</p>
            <a href="/categories/sample-id" class="btn btn-outline-primary">View Products</a>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card category-card h-100">
          <div class="card-body text-center">
            <h3 class="card-title">Home & Kitchen</h3>
            <p class="card-text">Explore top items in Home & Kitchen category</p>
            <a href="/categories/sample-id" class="btn btn-outline-primary">View Products</a>
          </div>
        </div>
      </div>
      {{/categories}}
    </div>
  </div>
</section>

<!-- Featured Products Section -->
<section class="products-section py-5 bg-light">
  <div class="container">
    <h2 class="text-center mb-4">Featured Products</h2>
    <div class="row">
      {{#each products}}
      <div class="col-md-4 mb-4">
        <div class="card product-card h-100">
          <div class="card-body text-center">
            <h3 class="card-title">{{this.name}}</h3>
            <p class="card-text">€{{this.price}}</p>
            <p class="card-text">{{this.description}}</p>
            <div class="d-flex justify-content-center gap-2 mt-3">
              <form method="POST" action="/cart/add">
    <input type="hidden" name="product_id" value="{{this._id}}" />
    <input type="number" name="quantity" value="1" min="1" required />
    <div class="product-actions">
  <button type="submit" class="add-to-cart-btn" fdprocessedid="7o44go">Add to Cart</button>
  <a href="/products/680f6848e1edf82065ca0392" class="btn btn-outline-primary view-button">View Details</a>
</div>

</form>

            </div>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
</section>

<!-- Newsletter Section -->
<section class="newsletter-section py-5">
  <div class="container text-center">
    <h2 class="mb-3">Subscribe to Our Newsletter</h2>
    <p class="mb-4">Stay updated with our latest products and offers</p>
    <form class="newsletter-form d-flex justify-content-center" action="/newsletter/subscribe" method="POST">
      <div class="input-group" style="max-width: 400px;">
        <input type="email" name="email" class="form-control" placeholder="Your email address" required>
        <button type="submit" class="btn btn-primary">Subscribe</button>
      </div>
    </form>
  </div>
</section>

<!-- Toast on Server Render (for classic redirect + flash) -->
{{#if success_msg}}
<script>
  window.onload = function () {
    const toast = document.createElement("div");
    toast.className = "toast-notification";
    toast.innerText = "{{success_msg}}";
    toast.style.position = "fixed";
    toast.style.top = "20px";
    toast.style.right = "20px";
    toast.style.backgroundColor = "#28a745";
    toast.style.color = "#fff";
    toast.style.padding = "12px 20px";
    toast.style.borderRadius = "8px";
    toast.style.boxShadow = "0 2px 8px rgba(0,0,0,0.2)";
    toast.style.zIndex = 1000;
    toast.style.fontSize = "14px";
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
  };
</script>
{{/if}}

<!-- AJAX Add to Cart Script -->
<script>
document.querySelectorAll('.add-to-cart-form').forEach(form => {
  form.addEventListener('submit', function (e) {
    e.preventDefault(); // Prevent default form submission

    const formData = new FormData(form);

    // 1. Show immediate toast notification
    const toast = document.createElement("div");
    toast.className = "toast-notification";
    toast.innerText = "Adding item to cart...";
    toast.style.position = "fixed";
    toast.style.top = "20px";
    toast.style.right = "20px";
    toast.style.backgroundColor = "#007bff";
    toast.style.color = "#fff";
    toast.style.padding = "12px 20px";
    toast.style.borderRadius = "8px";
    toast.style.boxShadow = "0 2px 8px rgba(0,0,0,0.2)";
    toast.style.zIndex = 1000;
    toast.style.fontSize = "14px";
    document.body.appendChild(toast);

    // 2. Send AJAX request
    fetch('/cart/add', {
      method: 'POST',
      body: formData
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        toast.innerText = "Item successfully added to cart!";
        toast.style.backgroundColor = "#28a745";
      } else {
        toast.innerText = data.message || "Failed to add item.";
        toast.style.backgroundColor = "#dc3545";
      }
    })
    .catch(err => {
      console.error("Fetch error:", err);
      toast.innerText = "Something went wrong.";
      toast.style.backgroundColor = "#dc3545";
    });

    // 3. Auto-remove toast after 3 seconds
    setTimeout(() => {
      toast.remove();
    }, 3000);
  });
});
</script>

