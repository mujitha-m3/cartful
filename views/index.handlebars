<!-- In <head> -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<!-- Before </body> -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>


<!-- Hero Section -->
<section class="hero-section text-center py-5">
  <div class="container">
    <h1 class="display-4">Welcome to Our Store</h1>
    <p class="lead mb-4">Discover amazing products at great prices</p>
    <a href="/login" class="btn btn-primary btn-lg">SHOP NOW</a>
  </div>
</section>

<!-- Discounted Products Section -->
{{#if discountedProducts.length}}
<section class="discounted-section py-5">
  <div class="container">
    <h2 class="text-center mb-4 text-danger">Hot Deals</h2>
    <div class="swiper discounted-swiper">
      <div class="swiper-wrapper">
        {{#each discountedProducts}}
        <div class="swiper-slide">
          <div class="card product-card h-100">
            {{#if this.image_url}}
            <img src="{{this.image_url}}" class="card-img-top" alt="{{this.alt_text}}" style="height: 200px; object-fit: contain;">
            {{else}}
            <img src="/images/default-product.png" class="card-img-top" alt="Default product image" style="height: 200px; object-fit: contain;">
            {{/if}}
            <div class="card-body text-center">
              <h3 class="card-title">{{this.name}}</h3>
              <p class="card-text">
                <span class="text-decoration-line-through text-muted me-2">€{{this.price}}</span>
                <span class="fw-bold text-danger">€{{this.finalPrice}}</span>
              </p>
              <p class="card-text">{{this.description}}</p>
              <form method="POST" action="/cart/add" class="add-to-cart-form">
                <input type="hidden" name="product_id" value="{{this._id}}" />
                <input type="number" name="quantity" value="1" min="1" required class="quantity-input" style="width: 196px;" />
                <div class="d-flex">
                <button type="submit" class="btn btn-primary add-to-cart-button">Add to Cart</button>
                <a href="/products/view/{{this._id}}" class="btn btn-outline-primary view-button">View Details</a>
                </div>
              </form>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
      <div class="swiper-pagination"></div>
      <div class="swiper-button-next"></div>
      <div class="swiper-button-prev"></div>
    </div>
  </div>
</section>
{{/if}}

<!-- Categories Section -->
<section class="categories-section py-5">
  <div class="container">
    <h2 class="text-center mb-4">Browse Categories</h2>
    <div class="swiper categories-swiper">
      <div class="swiper-wrapper">
        {{#each categories}}
        <div class="swiper-slide">
          <div class="card category-card h-100">
            <div class="card-body text-center">
              <h3 class="card-title">{{this.name}}</h3>
              <p class="card-text">Explore top items in {{this.name}} category</p>
              <a href="/products/viewproducts?category={{this._id}}" class="btn btn-outline-primary">View Products</a>
            </div>
          </div>
        </div>
        {{/each}}

        {{^categories}}
        <!-- Default categories (same layout, repeated) -->
        <div class="swiper-slide">
          <div class="card category-card h-100">
            <div class="card-body text-center">
              <h3 class="card-title">Electronics</h3>
              <p class="card-text">Explore top items in Electronics category</p>
              <a href="/categories/sample-id" class="btn btn-outline-primary">View Products</a>
            </div>
          </div>
        </div>
        <!-- Add Fashion & Home & Kitchen similarly -->
        {{/categories}}
      </div>
      <div class="swiper-pagination"></div>
      <div class="swiper-button-next"></div>
      <div class="swiper-button-prev"></div>
    </div>
  </div>
</section>


<!-- Featured Products Section -->
<section class="products-section py-5 bg-light">
  <div class="container">
    <h2 class="text-center mb-4">Featured Products</h2>
    <div class="swiper products-swiper">
      <div class="swiper-wrapper">
        {{#each products}}
        <div class="swiper-slide">
          <div class="card product-card h-100">
            {{#if this.image_url}}
            <img src="{{this.image_url}}" class="card-img-top" alt="{{this.alt_text}}" style="height: 200px; object-fit: contain;">
            {{else}}
            <img src="/images/default-product.png" class="card-img-top" alt="Default product image" style="height: 200px; object-fit: contain;">
            {{/if}}
            <div class="card-body text-center">
              <h3 class="card-title">{{this.name}}</h3>
              <p class="card-text">€{{this.price}}</p>
              <p class="card-text">{{this.description}}</p>
              <form method="POST" action="/cart/add" class="add-to-cart-form">
                <input type="hidden" name="product_id" value="{{this._id}}" />
                <input type="number" name="quantity" value="1" min="1" required class="quantity-input" style="width: 196px;" />
                <div class="d-flex">
                  <button type="submit" class="btn btn-primary add-to-cart-button">Add to Cart</button>
                  <a href="/products/view/{{this._id}}" class="btn btn-outline-primary view-button">View Details</a>
                </div>
              </form>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
      <div class="swiper-pagination"></div>
      <div class="swiper-button-next"></div>
      <div class="swiper-button-prev"></div>
    </div>
  </div>
</section>





<!-- Newsletter Section -->
<section class="newsletter-section py-5">
  <div class="container text-center">
    <h2 class="mb-3">Subscribe to Our Newsletter</h2>
    <p class="mb-4">Stay updated with our latest products and offers</p>
    <form class="newsletter-form d-flex justify-content-center" action="/newsletter/subscribe" method="POST">
      <div class="input-group" style="max-width: 400px;">
        <input type="email" name="email" class="form-control" placeholder="Your email address" required>
        <button type="submit" class="btn btn-primary">Subscribe</button>
      </div>
    </form>
  </div>
</section>

<!-- Toast on Server Render (for classic redirect + flash) -->
{{#if success_msg}}
<script>
  window.onload = function () {
    const toast = document.createElement("div");
    toast.className = "toast-notification";
    toast.innerText = "{{success_msg}}";
    toast.style.position = "fixed";
    toast.style.top = "20px";
    toast.style.right = "20px";
    toast.style.backgroundColor = "#28a745";
    toast.style.color = "#fff";
    toast.style.padding = "12px 20px";
    toast.style.borderRadius = "8px";
    toast.style.boxShadow = "0 2px 8px rgba(0,0,0,0.2)";
    toast.style.zIndex = 1000;
    toast.style.fontSize = "14px";
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
  };
</script>
{{/if}}

<script>
  new Swiper('.categories-swiper', {
    slidesPerView: 1,
    spaceBetween: 20,
    loop: true,
    navigation: {
      nextEl: '.categories-section .swiper-button-next',
      prevEl: '.categories-section .swiper-button-prev',
    },
    pagination: {
      el: '.categories-section .swiper-pagination',
      clickable: true,
    },
    breakpoints: {
      768: { slidesPerView: 2 },
      992: { slidesPerView: 3 }
    }
  });

  new Swiper('.products-swiper', {
    slidesPerView: 1,
    spaceBetween: 20,
    loop: true,
    navigation: {
      nextEl: '.products-section .swiper-button-next',
      prevEl: '.products-section .swiper-button-prev',
    },
    pagination: {
      el: '.products-section .swiper-pagination',
      clickable: true,
    },
    breakpoints: {
      768: { slidesPerView: 2 },
      992: { slidesPerView: 3 }
    }
  });

new Swiper('.discounted-swiper', {
  slidesPerView: 1,
  spaceBetween: 20,
  loop: true,
  navigation: {
    nextEl: '.discounted-section .swiper-button-next',
    prevEl: '.discounted-section .swiper-button-prev',
  },
  pagination: {
    el: '.discounted-section .swiper-pagination',
    clickable: true,
  },
  breakpoints: {
    768: { slidesPerView: 2 },
    992: { slidesPerView: 3 }
  }
});
</script>
