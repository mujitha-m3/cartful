<main role="main" aria-labelledby="wishlist-heading">
  <h1 id="wishlist-heading">My Wishlist</h1>

  {{#if wishlist.length}}
    <section aria-labelledby="wishlist-heading" class="mt-4">
      <div class="row row-cols-1 row-cols-md-3 g-4">
        {{#each wishlist}}
          {{#if this.product}} <!-- Check if product exists -->
            <div class="col">
              <article class="card h-100 shadow-sm" aria-labelledby="product-{{this.product._id}}-name">
                <img
                src="{{this.product.image_url}}"
                class="card-img-top"
                alt="Image of {{this.product.name}}"
                loading="lazy"
                style="object-fit: cover; height: 200px"
                />
                <div class="card-body d-flex flex-column">
                  <h2 class="h6 card-title" id="product-{{this.product._id}}-name">{{this.product.name}}</h2>
                  <p class="card-text" aria-label="Price: {{this.product.price}} euros">{{this.product.price}} €</p>

                  <div style="width: 100%; margin-top: 10px;">
                    <form class="add-to-cart-form" aria-label="Add {{this.product.name}} to cart">
                      <input type="hidden" name="product_id" value="{{this.product._id}}">
                      {{#if ../csrfToken}}
                      <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                      {{/if}}
                      <button type="submit" class="btn btn-primary add-to-cart-button" style="min-width: 44px; min-height: 44px; padding: 12px;" aria-label="Add to Cart">Add to Cart</button>
                    </form>
                  </div>

                  <form action="/wishlist/remove/{{this.product._id}}" method="POST" class="mt-2" aria-label="Remove {{this.product.name}} from wishlist">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                  </form>
                </div>
              </article>
            </div>
          {{/if}}
        {{/each}}
      </div>
    </section>
  {{else}}
    <p class="mt-3" aria-live="polite">You haven't added anything to your wishlist yet.</p>
  {{/if}}

  <a href="/profile" class="btn btn-outline-secondary mt-4" aria-label="Back to your account">⬅ Back to Account</a>
</main>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Handle server-rendered flash messages
    const successMsg = "{{success_msg}}";
    const errorMsg = "{{error_msg}}";
    
    if (successMsg || errorMsg) {
      showToastNotification(successMsg || errorMsg, successMsg ? 'success' : 'error');
    }

    // Add to cart form handling
    document.querySelectorAll('.add-to-cart-form').forEach(form => {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        const formData = new FormData(form);
        const product_id = formData.get('product_id');
        
        showToastNotification('Adding item to cart...', 'info');
        
        fetch('/cart/add', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ product_id })
        })
        .then(res => res.json())
        .then(data => {
          showToastNotification(data.message, data.success ? 'success' : 'error');
        })
        .catch(() => {
          showToastNotification('Failed to add item to cart', 'error');
        });
      });
    });

    // Helper function to show toast notifications
    function showToastNotification(message, type) {
      // Remove any existing notifications
      document.querySelectorAll('.toast-notification').forEach(el => el.remove());
      
      const colors = {
        success: '#28a745',
        error: '#dc3545',
        info: '#17a2b8'
      };
      
      const toast = document.createElement("div");
      toast.className = "toast-notification";
      toast.innerText = message;
      toast.style = `
        position: fixed;
        top: 20px;
        right: 20px;
        background-color: ${colors[type] || '#17a2b8'};
        color: #fff;
        padding: 12px 20px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        z-index: 1000;
        font-size: 14px;
        animation: slideIn 0.3s ease-out;
      `;
      
      document.body.appendChild(toast);
      
      setTimeout(() => {
        toast.style.animation = 'fadeOut 0.3s ease-out';
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }
  });
</script>

<style>
  @keyframes slideIn {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }
  
  @keyframes fadeOut {
    from { opacity: 1; }
    to { opacity: 0; }
  }
</style>