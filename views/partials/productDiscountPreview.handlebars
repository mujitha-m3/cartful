<main class="container py-4" role="main">

  <section aria-labelledby="product-title" class="row">
    <div class="col-md-6 text-center">
      <img
        src="{{product.image_url}}"
        alt="{{#if product.alt_text}}{{product.alt_text}}{{else}}{{product.name}}{{/if}}"
        class="img-fluid rounded shadow"
        style="max-height: 450px;"
      />
    </div>

    
    <div class="col-md-6">
      <h1 id="product-title" class="mb-3">{{product.name}}</h1>

      
      <div aria-live="polite">
        {{#if product.isDiscountActive}}
          <p class="h4 text-danger fw-bold">
            Now: €{{product.discountedPrice}}
            <span class="text-decoration-line-through text-muted small">Was: €{{product.price}}</span>
          </p>
          <p class="text-muted">Discount valid until {{formatDate product.discount.end_date}}</p>
        {{else}}
          <p class="h4 fw-bold">Price: €{{product.price}}</p>
        {{/if}}
      </div>

   
      <p class="mt-3">{{product.description}}</p>
      {{#if product.lifecycle.expiry_date}}
        <p><strong>Expires on:</strong> {{formatDate product.lifecycle.expiry_date}}</p>
      {{/if}}

      <!-- Season Tag  -->
      {{#if product.season}}
        <p><strong>Season:</strong> {{product.season}}</p>
      {{/if}}

      <!-- Admin Preview Message -->
      <aside class="alert alert-info mt-4" role="note">
        This is a <strong>preview</strong> of how the discount will appear to the customer.
      </aside>
    </div>
  </section>

</main>
