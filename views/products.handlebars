<div class="products-container">
  <div class="products-header">
    <h2 class="page-title">Product Management</h2>
    <a href="/products/add-product" class="btn btn-primary">Add New Product</a>
  </div>

  <div class="search-container">
    <form class="search-form" method="GET" action="/products">
      <div class="input-group">
        <input type="text" name="search" placeholder="Search products by name..." value="{{searchQuery}}" class="search-input">
        <button type="submit" class="search-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="search-icon">
            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
          </svg>
          Search
        </button>
      </div>
    </form>
  </div>

  {{#if products.length}}
  <div class="table-responsive">
    <table class="product-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Price</th>
          <th>Stock</th>
          <th>Category</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each products}}
        <tr>
          <td class="product-name">{{this.name}}</td>
          <td class="product-price">${{this.price}}</td>
          <td class="product-stock {{#if (lt this.stock 5)}}low-stock{{/if}}">{{this.stock}}</td>
          <td class="product-category">{{this.categoryName}}</td>
          <td class="product-status">
            <span class="status-badge {{#if (eq this.status 'active')}}status-active{{else}}status-inactive{{/if}}">
              {{#if (eq this.status 'active')}}Active{{else}}Inactive{{/if}}
            </span>
          </td>
          <td class="product-actions">
            <div class="action-buttons">
              <a href="/products/edit/{{this._id}}" class="btn btn-edit" title="Edit">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="action-icon">
                  <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/>
                </svg>
              </a>
              <button onclick="event.preventDefault(); document.getElementById('del-{{this._id}}').submit();" 
                class="btn btn-delete" title="Delete">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="action-icon">
                  <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                  <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
                </svg>
              </button>
              <form id="del-{{this._id}}" action="/products/delete/{{this._id}}" method="POST" style="display:none;"></form>
            </div>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
    <div class="empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16" class="empty-icon">
        <path d="M8 1a2.5 2.5 0 0 1 2.5 2.5V4h-5v-.5A2.5 2.5 0 0 1 8 1zm3.5 3v-.5a3.5 3.5 0 1 0-7 0V4H1v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V4h-3.5zM2 5h12v9a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V5z"/>
      </svg>
      <h3>No Products Found</h3>
      <p>Try adjusting your search or add a new product</p>
      <a href="/products/add-product" class="btn btn-primary">Add Product</a>
    </div>
  {{/if}}
</div>

<style>
  /* Main Container */
  .products-container {
    max-width: 1200px;
    margin: 2rem auto;
    padding: 0 1rem;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }

  /* Header */
  .products-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .page-title {
    color: #2c3e50;
    font-weight: 600;
    margin: 0;
  }

  /* Search */
  .search-container {
    margin-bottom: 2rem;
  }

  .search-form {
    max-width: 500px;
  }

  .input-group {
    display: flex;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    border-radius: 4px;
    overflow: hidden;
  }

  .search-input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid #ddd;
    border-right: none;
    font-size: 1rem;
    transition: all 0.3s;
  }

  .search-input:focus {
    outline: none;
    border-color: #3498db;
  }

  .search-btn {
    background: #3498db;
    color: white;
    border: none;
    padding: 0 1.5rem;
    cursor: pointer;
    transition: background 0.3s;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
  }

  .search-btn:hover {
    background: #2980b9;
  }

  .search-icon {
    margin-right: 0.5rem;
  }

  /* Table */
  .table-responsive {
    overflow-x: auto;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
    border-radius: 8px;
  }

  .product-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
  }

  .product-table th {
    background: #3498db;
    color: white;
    padding: 1rem;
    text-align: left;
    font-weight: 500;
  }

  .product-table td {
    padding: 1rem;
    border-bottom: 1px solid #eee;
    vertical-align: middle;
  }

  .product-table tr:hover {
    background: #f8f9fa;
  }

  /* Status Badges */
  .status-badge {
    padding: 0.35rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 500;
    display: inline-block;
  }

  .status-active {
    background: #d4edda;
    color: #155724;
  }

  .status-inactive {
    background: #f8d7da;
    color: #721c24;
  }

  /* Stock */
  .low-stock {
    color: #dc3545;
    font-weight: 600;
  }

  /* Action Buttons */
  .action-buttons {
    display: flex;
    gap: 0.5rem;
  }

  .btn {
    padding: 0.5rem;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
    font-size: 0.9rem;
  }

  .btn-edit {
    background: #ffc107;
    color: #212529;
  }

  .btn-edit:hover {
    background: #e0a800;
  }

  .btn-delete {
    background: #dc3545;
    color: white;
  }

  .btn-delete:hover {
    background: #c82333;
  }

  .btn-primary {
    background: #3498db;
    color: white;
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    border-radius: 4px;
  }

  .btn-primary:hover {
    background: #2980b9;
  }

  .action-icon {
    width: 16px;
    height: 16px;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    background: white;
    border-radius: 8px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
  }

  .empty-icon {
    color: #6c757d;
    margin-bottom: 1rem;
  }

  .empty-state h3 {
    color: #343a40;
    margin-bottom: 0.5rem;
  }

  .empty-state p {
    color: #6c757d;
    margin-bottom: 1.5rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .products-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .product-table th, 
    .product-table td {
      padding: 0.75rem 0.5rem;
      font-size: 0.9rem;
    }
  }
</style>