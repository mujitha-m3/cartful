<main>
  <section class="login-section">
    {{#if errorMessage}}
    <div class="alert alert-danger" role="alert" aria-live="assertive">{{errorMessage}}</div>
    {{/if}}

    {{#if successMessage}}
    <div class="alert alert-success" role="alert" aria-live="polite">{{successMessage}}</div>
    {{/if}}
    <h1 id="forgot-password-heading">Forgot Password</h1>
    <form action="/api/forgotPasswordSendCode" method="POST" aria-labelledby="forgot-password-heading">
      <label for="email">Enter your registered email address:</label>
      <input type="email" id="email" name="email" required aria-required="true" autocomplete="email" />
      <button type="submit" class="login-btn">Send Verification Code</button>
    </form>
    <div class="login-options">
      <a href="/login" class="link-small">Return to Login</a>
    </div>
  </section>
</main>