<h1 class="mb-4">Our Products</h1>

<section aria-label="Product listing">
  <div class="row row-cols-1 row-cols-md-3 g-4">
    {{#each products}}
    <div class="col">
      <article class="card h-100 shadow-sm">
        <!-- Clickable image and title link -->
        <a href="/products/view/{{this._id}}" class="text-decoration-none text-dark">
          <img
            src="{{this.image_url}}"
            class="card-img-top"
            alt="{{this.alt_text}}"
            loading="lazy"
            height="200"
            style="object-fit: cover;"
          />
          <div class="card-body">
            <h2 class="card-title h5">{{this.name}}</h2>
          </div>
        </a>

        <!-- Product details -->
        <div class="card-body d-flex flex-column pt-0">
          <p class="card-text flex-grow-1">{{this.description}}</p>

          {{#if this.discount_type}}
            {{#if (eq this.discount_type "percentage")}}
              <p class="text-danger mb-1">-{{this.discount_value}}% Off</p>
            {{else if (eq this.discount_type "fixed")}}
              <p class="text-danger mb-1">-{{this.discount_value}} € Off</p>
            {{/if}}
          {{/if}}

          {{#if this.original_price}}
            <p class="fw-bold mb-1">{{this.finalPrice}} €</p>
            <p class="text-muted text-decoration-line-through small">{{this.original_price}} €</p>
          {{else}}
            <p class="fw-bold mb-1">{{this.price}} €</p>
          {{/if}}

          <form method="POST" action="/cart/add" class="add-to-cart-form">
            <input type="hidden" name="product_id" value="{{this._id}}" />
            <div class="d-flex">
            <button type="submit" class="btn btn-primary add-to-cart-button">Add to Cart</button>
            <a href="/products/view/{{this._id}}" class="btn btn-outline-primary view-button">View Details</a>
            </div>
            </form>
        </div>
      </article>
    </div>
    {{/each}}
  </div>
</section>
