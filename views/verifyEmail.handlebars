<section class="register-section">
  <h2>Email Verification</h2>

  <!-- Email Verification Form -->
  <form action="/api/verifyEmail" method="POST" aria-label="Email Verification Form">
    <fieldset>
      <label for="email">Enter Your Email:</label>
      <input type="email" id="email" name="email" required autocomplete="email">
    </fieldset>

    <fieldset>
      <label for="verificationCode">Verification Code:</label>
      <input type="text" id="verificationCode" name="verificationCode" required autocomplete="one-time-code">
    </fieldset>

    <button type="submit" class="login-btn">Verify Email</button>
  </form>

  <!-- Resend Code -->
  <form action="/api/resendCode" method="POST" aria-label="Resend Verification Code Form" style="margin-top: 1rem;">
    <input type="hidden" name="email" value="{{email}}">
    <button type="submit" class="login-btn">Resend Verification Code</button>
  </form>
</section>