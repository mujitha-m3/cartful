<h2>Update Product</h2>

<form action="/products/update/{{product._id}}" method="post">
  <!-- Product Name -->
  <div class="input-group">
    <label for="name">Product Name:</label>
    <input type="text" id="name" name="name" value="{{product.name}}" required>
  </div>

  <!-- Slug -->
  <div class="input-group">
    <label for="slug">Slug:</label>
    <input type="text" id="slug" name="slug" value="{{product.slug}}" required>
  </div>

  <!-- Description -->
  <div class="input-group">
    <label for="description">Description:</label>
    <textarea id="description" name="description">{{product.description}}</textarea>
  </div>

  <!-- Pricing -->
  <div class="input-group">
    <label for="price">Price:</label>
    <input type="number" id="price" name="price" value="{{product.price}}" required step="0.01">
  </div>

  <div class="input-group">
    <label for="original_price">Original Price:</label>
    <input type="number" id="original_price" name="original_price" value="{{product.original_price}}" step="0.01">
  </div>

  <div class="input-group">
    <label for="discount">Discount:</label>
    <input type="number" id="discount" name="discount" value="{{product.discount.amount}}" step="0.01">
  </div>

  <!-- Inventory -->
  <div class="input-group">
    <label for="stock">Stock:</label>
    <input type="number" id="stock" name="stock" value="{{product.stock}}">
  </div>

  <!-- Images -->
  <div class="input-group">
    <label for="image_url">Image URL:</label>
    <input type="text" id="image_url" name="image_url" value="{{product.image_url}}">
  </div>

  <div class="input-group">
    <label for="thumbnail_url">Thumbnail URL:</label>
    <input type="text" id="thumbnail_url" name="thumbnail_url" value="{{product.thumbnail_url}}">
  </div>

  <div class="input-group">
    <label for="alt_text">Alt Text:</label>
    <input type="text" id="alt_text" name="alt_text" value="{{product.alt_text}}">
  </div>

  <!-- Category -->
  <div class="input-group">
    <label for="category_id">Category:</label>
    <select id="category_id" name="category_id">
      {{#each categories}}
        <option value="{{_id}}" {{#ifEquals _id product.category_id._id}}selected{{/ifEquals}}>{{name}}</option>
      {{/each}}
    </select>
  </div>

  <!-- Allowed Countries -->
  <div class="input-group">
    <label for="allowed_countries">Allowed Countries:</label>
    <input type="text" id="allowed_countries" name="allowed_countries" value="{{product.allowed_countries}}">
  </div>

  <!-- Settings -->
  <div class="input-group">
    <label>
      <input type="checkbox" id="is_featured" name="is_featured" {{#if product.is_featured}}checked{{/if}}>
      Featured Product
    </label>
  </div>

  <div class="input-group">
    <label for="status">Status:</label>
    <select name="status" id="status">
      <option value="active" {{#ifEquals product.status 'active'}}selected{{/ifEquals}}>Active</option>
      <option value="inactive" {{#ifEquals product.status 'inactive'}}selected{{/ifEquals}}>Inactive</option>
      <option value="draft" {{#ifEquals product.status 'draft'}}selected{{/ifEquals}}>Draft</option>
    </select>
  </div>

  <!-- Submit -->
  <div class="input-group">
    <button type="submit" class="btn btn-primary">Update Product</button>
    <a href="/products" class="btn">Cancel</a>
  </div>
</form>
