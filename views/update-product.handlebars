<main class="profile-wrapper">
  <section class="profile-card">
    <div class="profile-header">
      <img src="{{user.profileImage}}" alt="Profile Image" class="profile-img">
      <div class="profile-details">
        <h2>{{user.fullName}}</h2>
        <p>{{user.email}}</p>
        <p>{{#if user.phone}}{{user.phone}}{{else}}Phone not provided{{/if}}</p>
      </div>
    </div>

    <div class="profile-actions">
      <a href="/wishlist" class="action-tile">
        <span class="action-icon">❤️</span>
        <span class="action-label">My Wishlist</span>
      </a>
    </div>

    <form method="POST" action="/profile/update" class="update-form">
      <h3>Update Profile</h3>
      <input type="text" name="fullName" value="{{user.fullName}}" placeholder="Full Name">
      <input type="email" name="email" value="{{user.email}}" placeholder="Email">
      <input type="tel" name="phone" value="{{user.phone}}" placeholder="Phone">
      <button type="submit">Update</button>
    </form>
  </section>
</main>
