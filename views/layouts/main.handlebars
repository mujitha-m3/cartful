<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>CartFul</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/style.css">

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
  <!-- Font Awesome for icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    /* Custom CSS to remove dropdown caret */
    .dropdown-toggle::after {
      display: none !important;
    }

    /* Dropdown animation styles */
    .dropdown-menu {
      display: block;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-10px);
      transition: all 0.3s ease;
      pointer-events: none;
    }

    .dropdown-menu.show {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      pointer-events: auto;
    }

    /* Smooth transition for dropdown items */
    .dropdown-item {
      transition: background-color 0.2s ease, transform 0.2s ease;
    }

    .dropdown-item:hover {
      transform: translateX(5px);
    }
  </style>
</head>

<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <header role="banner" class="mb-4">
    <nav class="navbar navbar-expand-lg custom-navbar" role="navigation" aria-label="Main navigation">
      <div class="container">
        <a class="navbar-brand d-flex align-items-center" href="/">
          <img src="/images/logo.png" alt="Cartful home page" class="me-2" style="height: 50px;">
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="visually-hidden" aria-live="polite">
          Keyboard shortcuts are available:
          - Press Ctrl + Alt + C to open the Cart page.
          - Press Ctrl + Alt + P to open the Profile page.
          - Press Ctrl + Alt + H to go to the Homepage.
          - Press Ctrl + Alt + W to open the Wishlist page.
          - Press Ctrl + Alt + O to open the Contact page.
          - Press Ctrl + Alt + A to add the first item to the Cart.
          - Press Ctrl + Alt + L to log out.
          - Press Ctrl + Alt + G to open the Categories page.
        </div>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            {{#if (includes user.roles "user")}}
            <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="/about">About Us</a></li>
            <li class="nav-item"><a class="nav-link" href="/contact">Contact Us</a></li>
            {{/if}}
            {{#if (includes user.roles "admin")}}
            <li class="nav-item"><a class="nav-link" href="/products">Products</a></li>
            <li class="nav-item"><a class="nav-link" href="/categories">Categories</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/discounts/search">Manage Discounts</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/orders">Manage Orders</a></li>
            {{/if}}
            {{#if (includes user.roles "user")}}
            <li class="nav-item"><a class="nav-link" href="/cart">Cart</a></li>
            {{/if}}

          </ul>

          <ul class="navbar-nav">
            {{#if user}}
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown"
                aria-expanded="false">
                <i class="fas fa-user"></i> {{user.fullName}}
              </a>
              <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
                <li><a class="dropdown-item" href="/profile"><i class="fas fa-user-circle me-2"></i>Profile</a></li>
                <li>
                  <hr class="dropdown-divider">
                </li>
                <li>
                  <form method="POST" action="/logout" class="d-inline">
                    <button type="submit" class="dropdown-item">
                      <i class="fas fa-sign-out-alt me-2"></i>Logout
                    </button>
                  </form>
                </li>
              </ul>
            </li>
            {{else}}
            <li class="nav-item">
              <a class="nav-link" href="/login">
                <i class="fas fa-sign-in-alt"></i> Login
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/register">
                <i class="fas fa-user-plus"></i> Register
              </a>
            </li>
            {{/if}}
            {{#if user._id}}
            <li class="nav-item">
              <a class="nav-link" href="/cart" aria-label="Cart ({{cartItemCount}})">
                <i class="fas fa-cart-shopping"></i>
                Cart ({{cartItemCount}})
              </a>
            </li>
            {{/if}}
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <main id="main-content" class="container" role="main">
    {{{body}}}
  </main>

  <footer role="contentinfo" class="text-center mt-5">
    <p>&copy; 2025 Cartful Inc. All rights reserved.</p>
  </footer>

  <!-- Bootstrap 5 JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/cart.js"></script>
  <script src="/js/shortcuts.js"></script>
  <script>
    // Enhanced dropdown interaction
    document.addEventListener('DOMContentLoaded', function () {
      const dropdowns = document.querySelectorAll('.dropdown');

      dropdowns.forEach(dropdown => {
        const toggle = dropdown.querySelector('.dropdown-toggle');
        const menu = dropdown.querySelector('.dropdown-menu');

        toggle.addEventListener('click', function (e) {
          e.preventDefault();
          const isShowing = menu.classList.contains('show');

          if (!isShowing) {
            // Close any other open dropdowns
            document.querySelectorAll('.dropdown-menu.show').forEach(openMenu => {
              if (openMenu !== menu) {
                openMenu.classList.remove('show');
              }
            });
          }

          // Bootstrap will handle the toggle via data attributes
        });
      });
    });

    document.querySelectorAll('.add-to-cart-form').forEach(form => {
      form.addEventListener('submit', function (e) {
        e.preventDefault();

        const formData = new FormData(form);
        const product_id = formData.get('product_id');
        const quantity = formData.get('quantity') || 1;

        // Remove any existing toast
        document.querySelectorAll('.toast-notification').forEach(t => t.remove());

        const toast = document.createElement("div");
        toast.className = "toast-notification";
        toast.innerText = "Adding item to cart...";
        toast.style = `
      position: fixed;
      top: 20px;
      right: 20px;
      background-color: #007bff;
      color: #fff;
      padding: 12px 20px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.2);
      z-index: 1000;
      font-size: 14px;
    `;
        document.body.appendChild(toast);

        fetch('/cart/add', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ product_id, quantity })
        })
          .then(res => res.json())
          .then(data => {
            toast.innerText = data.message || 'Response received.';
            toast.style.backgroundColor = data.success ? '#28a745' : '#dc3545';
          })
          .catch(() => {
            toast.innerText = 'Something went wrong.';
            toast.style.backgroundColor = '#dc3545';
          });

        setTimeout(() => toast.remove(), 3000);
      });
    });
  </script>

</body>

</html>