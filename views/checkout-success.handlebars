<main class="container py-5" role="main" aria-labelledby="thank-you-heading">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center p-5">
          <div class="mb-4" aria-hidden="true">
            <i class="fas fa-check-circle text-success" style="font-size: 4rem;"></i>
          </div>
          
          <h1 class="display-4 mb-4" id="thank-you-heading">Thank You!</h1>
          <p class="lead mb-4">Your order has been successfully placed</p>
          
          {{#if success_msg}}
          <div class="alert alert-success" role="alert" aria-live="polite">
            {{success_msg}}
          </div>
          {{/if}}

          <div class="order-info my-4 text-start">
            <h2 class="h5 mb-3">What's Next?</h2>
            <ul class="list-unstyled">
              <li class="mb-2">
                <i class="fas fa-envelope me-2 text-primary" aria-hidden="true"></i>
                You will receive an order confirmation email shortly
              </li>
              <li class="mb-2">
                <i class="fas fa-box me-2 text-primary" aria-hidden="true"></i>
                We'll notify you when your order ships
              </li>
              <li class="mb-2">
                <i class="fas fa-question-circle me-2 text-primary" aria-hidden="true"></i>
                For any questions about your order, please contact our support team
              </li>
            </ul>
          </div>

          <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mt-4">
            <a href="/orders-history" class="btn btn-primary" aria-label="View your order history">
              <i class="fas fa-user me-2" aria-hidden="true"></i>View Order History
            </a>
            <a href="/" class="btn btn-outline-secondary" aria-label="Continue shopping on the homepage">
              <i class="fas fa-shopping-bag me-2" aria-hidden="true"></i>Continue Shopping
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
