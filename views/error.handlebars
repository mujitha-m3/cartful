{{!-- error.handlebars --}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error {{error.status}}</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <h1>Error {{error.status}}</h1>
    <p>{{error.message}}</p>
    {{#if error.stack}}
      <pre>{{error.stack}}</pre>
    {{/if}}
    <a href="/products" class="btn btn-primary">Go Back to Products</a>
  </div>
</body>
</html>
