<main>
  <h1 class="mb-4">Order Confirmation</h1>

  <!-- 👤 Customer Info Section -->
  <div class="card mb-4">
    <div class="card-header bg-light">
      <h2 id="customer-heading" class="h5 mb-0">👤 Customer Information</h2>
    </div>
    <div class="card-body">
      <dl class="row mb-0">
        <dt class="col-sm-3 fw-semibold">Name</dt>
        <dd class="col-sm-9">{{firstName}} {{lastName}}</dd>

        <dt class="col-sm-3 fw-semibold">Phone</dt>
        <dd class="col-sm-9">{{phone}}</dd>

        <dt class="col-sm-3 fw-semibold">Address</dt>
        <dd class="col-sm-9">{{address.street}}, {{address.postal}} {{address.city}}</dd>

        <dt class="col-sm-3 fw-semibold">Shipping</dt>
        <dd class="col-sm-9">{{shippingMethod}} — <span class="fw-bold">{{shippingFee}} €</span></dd>

        <dt class="col-sm-3 fw-semibold">Payment</dt>
        <dd class="col-sm-9">{{paymentMethod}}</dd>
      </dl>
    </div>
  </div>

  <!-- 🛒 Order Summary -->
  <div class="card">
    <div class="card-header bg-light">
      <h2 id="summary-heading" class="h5 mb-0">🛒 Order Summary</h2>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive" role="region" aria-labelledby="summary-heading">
        <table class="table table-bordered align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th scope="col">Item</th>
              <th scope="col">Qty</th>
              <th scope="col">Price</th>
              <th scope="col">Subtotal</th>
            </tr>
          </thead>
          <tbody>
            {{#each cart}}
            <tr>
              <td>{{this.product.name}}</td>
              <td>{{this.quantity}}</td>
              <td>
                {{#if (lt this.discountedPrice this.originalPrice)}}
                  <span class="text-muted text-decoration-line-through">{{this.originalPrice}} €</span>
                  <span class="fw-bold text-success ms-1">{{this.discountedPrice}} €</span>
                {{else}}
                  {{this.originalPrice}} €
                {{/if}}
              </td>
              <td>
                {{#if (lt this.discountedPrice this.originalPrice)}}
                  {{multiply this.discountedPrice this.quantity}} €
                {{else}}
                  {{multiply this.originalPrice this.quantity}} €
                {{/if}}
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
    <div class="card-footer text-end">
      <p class="mb-1"><span class="fw-semibold">Subtotal:</span> {{subtotal}} €</p>
      <p class="mb-1"><span class="fw-semibold">Shipping:</span> {{shippingFee}} €</p>
      <h4 class="fw-bold mb-0">Total: {{total}} €</h4>
    </div>
  </div>

  <!-- ✅ Confirm Button -->
  {{#if (eq paymentMethod "cod")}}
  <form action="/checkout/place-order" method="POST" class="mt-4 text-center">
    <input type="hidden" name="firstName" value="{{firstName}}">
    <input type="hidden" name="lastName" value="{{lastName}}">
    <input type="hidden" name="phone" value="{{phone}}">
    <input type="hidden" name="shippingStreet" value="{{address.street}}">
    <input type="hidden" name="shippingPostal" value="{{address.postal}}">
    <input type="hidden" name="shippingCity" value="{{address.city}}">
    <input type="hidden" name="shippingMethod" value="{{shippingMethod}}">
    <input type="hidden" name="payment_method" value="{{paymentMethod}}">
    <input type="hidden" name="subtotal" value="{{subtotal}}">
    <input type="hidden" name="shippingFee" value="{{shippingFee}}">
    <input type="hidden" name="total" value="{{total}}">
    <button type="submit" class="btn btn-lg btn-success mt-3 px-4">✅ Confirm Order</button>
  </form>
  {{else}}
  <form action="/checkout/stripe" method="POST" class="mt-4 text-center">
    <input type="hidden" name="firstName" value="{{firstName}}">
    <input type="hidden" name="lastName" value="{{lastName}}">
    <input type="hidden" name="phone" value="{{phone}}">
    <input type="hidden" name="shippingStreet" value="{{address.street}}">
    <input type="hidden" name="shippingPostal" value="{{address.postal}}">
    <input type="hidden" name="shippingCity" value="{{address.city}}">
    <input type="hidden" name="shippingMethod" value="{{shippingMethod}}">
    <input type="hidden" name="payment_method" value="{{paymentMethod}}">
    <input type="hidden" name="subtotal" value="{{subtotal}}">
    <input type="hidden" name="shippingFee" value="{{shippingFee}}">
    <input type="hidden" name="total" value="{{total}}">
    <button type="submit" class="btn btn-lg btn-primary mt-3 px-4">💳 Pay with Card</button>
  </form>
  {{/if}}
  <div class="text-center mt-3">
    <a href="/cart" class="btn btn-outline-danger">← Back to Cart</a>
  </div>
</main>
