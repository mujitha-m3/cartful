<div class="cart-container">
  <h2 class="cart-title">Your Cart</h2>

  {{#if message}}
    <div class="cart-message" role="alert" aria-live="assertive">{{message}}</div>
  {{/if}}
  <div id="cart-status" aria-live="polite" class="visually-hidden"></div>
  
  {{#if cartItems.length}}
    <table class="cart-table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Price</th>
          <th>Qty</th>
          <th>Total</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each cartItems}}
          <tr class="cart-item">
            <td>{{this.product_id.name}}</td>
            <td class="price">
              {{#if this.discount_applied}}
                <span class="original-price">{{formatPrice this.product_id.price}}</span>
                <span class="discounted-price">{{formatPrice this.unit_price}}</span>
              {{else}}
                {{formatPrice this.unit_price}}
              {{/if}}
            </td>
            <td>
              <form method="POST" action="/cart/update/{{this._id}}" aria-label="Update quantity for {{this.product_id.name}}">
                <input type="number" name="quantity" value="{{this.quantity}}" min="1" class="quantity-input" aria-label="Quantity for {{this.product_id.name}}" />
                <button type="submit" class="update-btn" aria-label="Update quantity for {{this.product_id.name}}">Update</button>
              </form>
            </td>
            <td class="price">€{{this.total_price}}</td>
            <td class="d-flex">
              <form method="POST" action="/cart/remove/{{this._id}}" aria-label="Remove {{this.product_id.name}} from cart">
                <button type="submit" class="remove-item-btn" aria-label="Remove {{this.product_id.name}} from cart">Remove</button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>

    <div class="cart-summary">
      <div class="summary-row">
        <span>Subtotal</span>
        <span>
          {{#if (eq (calculateTotal cartItems) 0)}}0{{else}}€{{calculateTotal cartItems}}{{/if}}
        </span>
      </div>
      <div class="cart-actions">
        <a href="/" class="continue-shopping">Continue Shopping</a>
        <a href="/checkout" class="checkout-btn">Proceed to Checkout</a>
      </div>
    </div>

  {{else}}
    <div class="empty-cart">
      <p>Your cart is empty. 🛒</p>
      <a href="/" class="cta-btn">Go to Shop</a>
    </div>
  {{/if}}
</div>

<script>
  if (window.location.hash === '#updated') {
    const status = document.getElementById('cart-status');
    if (status) {
      status.textContent = 'Cart updated.';
      status.classList.remove('visually-hidden');
      setTimeout(() => status.classList.add('visually-hidden'), 3000);
    }
  }
</script>
