<div class="cart-container">
  <h2 class="cart-title">Your Cart</h2>

  {{#if cartItems.length}}
    <table class="cart-table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Price</th>
          <th>Qty</th>
          <th>Total</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each cartItems}}
          <tr class="cart-item">
            <td>{{this.product_id.name}}</td>
            <td class="price">
              {{#if this.discount_applied}}
                <span class="original-price">{{formatPrice this.product_id.price}}</span>
                <span class="discounted-price">{{formatPrice this.unit_price}}</span>
              {{else}}
                {{formatPrice this.unit_price}}
              {{/if}}
            </td>
            <td>
              <form method="POST" action="/cart/update/{{this._id}}">
                <input type="number" name="quantity" value="{{this.quantity}}" min="1" class="quantity-input" />
                <button type="submit" class="update-btn">Update</button>
              </form>
            </td>
            <td class="price">€{{this.total_price}}</td>
            <td class="d-flex">
              <form method="POST" action="/cart/remove/{{this._id}}">
                <button type="submit" class="remove-item-btn">Remove</button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>

    <div class="cart-summary">
      <div class="summary-row">
        <span>Subtotal</span>
        <span>€{{calculateTotal cartItems}}</span>
      </div>
      <div class="cart-actions">
        <a href="/" class="continue-shopping">Continue Shopping</a>
        <a href="/checkout" class="checkout-btn">Proceed to Checkout</a>
      </div>
    </div>

  {{else}}
    <div class="empty-cart">
      <p>Your cart is empty. 🛒</p>
      <a href="/" class="cta-btn">Go to Shop</a>
    </div>
  {{/if}}
</div>
