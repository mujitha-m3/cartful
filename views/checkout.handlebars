<main>
  <h1 class="mb-4">Checkout</h1>

  <ul class="nav nav-tabs mb-3" id="checkoutTabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link active" id="order-tab" data-bs-toggle="tab" data-bs-target="#order" type="button" role="tab" aria-controls="order" aria-selected="true">
        1. Order Details
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="shipping-tab" data-bs-toggle="tab" data-bs-target="#shipping" type="button" role="tab" aria-controls="shipping" aria-selected="false">
        2. Shipping Method
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="payment-tab" data-bs-toggle="tab" data-bs-target="#payment" type="button" role="tab" aria-controls="payment" aria-selected="false">
        3. Payment
      </button>
    </li>
  </ul>

  <form action="/checkout/confirm" method="POST">
    <div class="tab-content" id="checkoutTabsContent" aria-live="polite">

      {{!-- Step 1: Order Details --}}
      <div class="tab-pane fade show active" id="order" role="tabpanel" aria-labelledby="order-tab" tabindex="0">
        <div class="row">
          <div class="col-md-6">
            <label for="firstName" class="form-label">First Name</label>
            <input
              type="text"
              id="firstName"
              name="firstName"
              class="form-control"
              required
              value="{{user.firstName}}"
              autocomplete="given-name"
            >
          </div>
          <div class="col-md-6">
            <label for="lastName" class="form-label">Last Name</label>
            <input
              type="text"
              id="lastName"
              name="lastName"
              class="form-control"
              required
              value="{{user.lastName}}"
              autocomplete="family-name"
            >
          </div>
        </div>

        <label for="phone" class="form-label mt-3">Phone Number</label>
        <input
          type="tel"
          id="phone"
          name="phone"
          class="form-control"
          required
          value="{{user.phone}}"
          autocomplete="tel"
        >

        <h5 class="mt-4">Shipping Address</h5>
        <div class="mb-3">
          <label for="shippingStreet" class="form-label">Street</label>
          <input
            type="text"
            id="shippingStreet"
            name="shippingStreet"
            class="form-control"
            required
            value="{{user.addressLine1}}"
            autocomplete="address-line1"
          >
        </div>
        <div class="row">
          <div class="col-md-6">
            <label for="shippingPostal" class="form-label">Postal Code</label>
            <input
              type="text"
              id="shippingPostal"
              name="shippingPostal"
              class="form-control"
              required
              value="{{user.postalCode}}"
              autocomplete="postal-code"
            >
          </div>
          <div class="col-md-6">
            <label for="shippingCity" class="form-label">City</label>
            <input
              type="text"
              id="shippingCity"
              name="shippingCity"
              class="form-control"
              required
              value="{{user.city}}"
              autocomplete="address-level2"
            >
          </div>
        </div>

        <button class="btn btn-primary mt-4" type="button" onclick="goToTab('shipping')">Save & Continue</button>
      </div>

      {{!-- Step 2: Shipping Method --}}
      <div class="tab-pane fade" id="shipping" role="tabpanel" aria-labelledby="shipping-tab" tabindex="0">
        <h5>Select Shipping Method</h5>

        <div class="row row-cols-1 row-cols-md-3 g-3" role="radiogroup">
          <div class="col">
            <label class="card p-3 border shadow-sm position-relative">
              <input type="radio" name="shippingMethod" value="Posti" class="form-check-input position-absolute top-0 end-0 m-2" required>
              <h6 class="card-title">Posti</h6>
              <p>2–4 business days – €4.90</p>
            </label>
          </div>

          <div class="col">
            <label class="card p-3 border shadow-sm position-relative">
              <input type="radio" name="shippingMethod" value="Matkahuolto" class="form-check-input position-absolute top-0 end-0 m-2" required>
              <h6 class="card-title">Matkahuolto</h6>
              <p>3–5 business days – €5.90</p>
            </label>
          </div>

          <div class="col">
            <label class="card p-3 border shadow-sm position-relative">
              <input type="radio" name="shippingMethod" value="Pickup" class="form-check-input position-absolute top-0 end-0 m-2" required>
              <h6 class="card-title">In-store Pickup</h6>
              <p>Ready next day – Free</p>
            </label>
          </div>
        </div>

        <div class="mt-4">
          <button class="btn btn-secondary me-2" type="button" onclick="goToTab('order')">Back</button>
          <button class="btn btn-primary" type="button" onclick="goToTab('payment')">Continue</button>
        </div>
      </div>

      {{!-- Step 3: Payment --}}
      <div class="tab-pane fade" id="payment" role="tabpanel" aria-labelledby="payment-tab" tabindex="0">
        <h5>Select Payment Method</h5>

        <div class="form-check mb-2">
          <input type="radio" name="paymentMethod" id="stripe" value="stripe" class="form-check-input" required>
          <label for="stripe" class="form-check-label">Credit/Debit Card (via Stripe)</label>
        </div>

        <div class="form-check">
          <input type="radio" name="paymentMethod" id="cod" value="cod" class="form-check-input">
          <label for="cod" class="form-check-label">Cash on Delivery</label>
        </div>

        <div class="mt-4">
          <button class="btn btn-secondary me-2" type="button" onclick="goToTab('shipping')">Back</button>
          <button class="btn btn-success" type="submit">Place Order</button>
        </div>
      </div>

    </div>
  </form>
</main>

<script>
  function goToTab(tabId) {
    const trigger = document.querySelector(`#${tabId}-tab`);
    if (trigger) new bootstrap.Tab(trigger).show();
  }
</script>
