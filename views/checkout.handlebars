<h2>Checkout</h2>

{{#if cartItems.length}}
  {{#if success_msg}}
    <div class="alert alert-success">{{success_msg}}</div>
  {{/if}}

  <form method="POST" action="/checkout" class="mt-4">
    <!-- Bootstrap Tabs -->
    <ul class="nav nav-tabs" id="checkoutTabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link {{#if (eq activeTab 'details')}}active{{/if}}" id="details-tab" data-bs-toggle="tab" data-bs-target="#details" type="button">Order Details</button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link {{#if (eq activeTab 'shipping')}}active{{/if}}" id="shipping-tab" data-bs-toggle="tab" data-bs-target="#shipping" type="button">Shipping</button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link {{#if (eq activeTab 'payment')}}active{{/if}}" id="payment-tab" data-bs-toggle="tab" data-bs-target="#payment" type="button">Payment</button>
      </li>
    </ul>

    <div class="tab-content p-3 border border-top-0" id="checkoutTabContent">

      <!-- Order Details Tab -->
      <div class="tab-pane fade {{#if (eq activeTab 'details')}}show active{{/if}}" id="details" role="tabpanel">
        <div class="row">
          <div class="col-md-6">
            <label>First Name</label>
            <input name="first_name" class="form-control" value="{{session.checkoutDetails.first_name}}" required>
          </div>
          <div class="col-md-6">
            <label>Last Name</label>
            <input name="last_name" class="form-control" value="{{session.checkoutDetails.last_name}}" required>
          </div>
        </div>

        <label class="mt-3">Phone</label>
        <input name="phone" class="form-control" value="{{session.checkoutDetails.phone}}" required>

        <label class="mt-3">Email</label>
        <input name="email" type="email" class="form-control" value="{{session.checkoutDetails.email}}" required>

        <h5 class="mt-4">Shipping Address</h5>
        <input name="shipping_address[line1]" class="form-control mb-2" value="{{session.checkoutDetails.shipping_address.line1}}">
        <input name="shipping_address[line2]" class="form-control mb-2" value="{{session.checkoutDetails.shipping_address.line2}}">
        <input name="shipping_address[city]" class="form-control mb-2" value="{{session.checkoutDetails.shipping_address.city}}">
        <input name="shipping_address[postal]" class="form-control mb-2" value="{{session.checkoutDetails.shipping_address.postal}}">
        <input name="shipping_address[country]" class="form-control mb-2" value="{{session.checkoutDetails.shipping_address.country}}">

        <h5 class="mt-4">Billing Address</h5>
        <input name="billing_address[line1]" class="form-control mb-2" value="{{session.checkoutDetails.billing_address.line1}}">
        <input name="billing_address[line2]" class="form-control mb-2" value="{{session.checkoutDetails.billing_address.line2}}">
        <input name="billing_address[city]" class="form-control mb-2" value="{{session.checkoutDetails.billing_address.city}}">
        <input name="billing_address[postal]" class="form-control mb-2" value="{{session.checkoutDetails.billing_address.postal}}">
        <input name="billing_address[country]" class="form-control mb-2" value="{{session.checkoutDetails.billing_address.country}}">

        <div class="mt-3 text-end">
          <button class="btn btn-primary" formaction="/checkout/save-details" formmethod="POST" type="submit">Save Details</button>
        </div>
      </div>

      <!-- Shipping Tab -->
      <div class="tab-pane fade {{#if (eq activeTab 'shipping')}}show active{{/if}}" id="shipping" role="tabpanel">
        <h5>Shipping Method</h5>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="shipping_method" value="Posti" {{#if (eq session.checkoutDetails.shipping_method "Posti")}}checked{{/if}}>
          <label class="form-check-label">Posti</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="shipping_method" value="Matkahuolto" {{#if (eq session.checkoutDetails.shipping_method "Matkahuolto")}}checked{{/if}}>
          <label class="form-check-label">Matkahuolto</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="shipping_method" value="Pickup" {{#if (eq session.checkoutDetails.shipping_method "Pickup")}}checked{{/if}}>
          <label class="form-check-label">In-store Pickup</label>
        </div>
      </div>

      <!-- Payment Tab -->
      <div class="tab-pane fade {{#if (eq activeTab 'payment')}}show active{{/if}}" id="payment" role="tabpanel">
        <h5>Payment Method</h5>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="payment_method" value="stripe" checked>
          <label class="form-check-label">Stripe (Card)</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="payment_method" value="cod">
          <label class="form-check-label">Cash on Delivery</label>
        </div>
      </div>
    </div>

    {{#if session.checkoutDetails}}
      <div class="text-end mt-4">
        <button class="btn btn-success" type="submit">Place Order</button>
      </div>
    {{else}}
      <p class="mt-3 text-danger">Please save order details before placing the order.</p>
    {{/if}}
  </form>

{{else}}
  <p>No items in cart to checkout.</p>
{{/if}}
