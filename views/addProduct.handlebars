<h2>Add Product</h2>

<form action="/products" method="post">
  <!-- Product Name -->
  <div class="input-group">
    <label for="name">Product Name:</label>
    <input type="text" id="name" name="name" required>
  </div>

  <!-- Slug -->
  <div class="input-group">
    <label for="slug">Slug:</label>
    <input type="text" id="slug" name="slug" required>
  </div>

  <!-- Description -->
  <div class="input-group">
    <label for="description">Description:</label>
    <textarea id="description" name="description"></textarea>
  </div>

  <!-- Pricing -->
  <div class="input-group">
    <label for="price">Price:</label>
    <input type="number" id="price" name="price" required step="0.01">
  </div>

  <div class="input-group">
    <label for="original_price">Original Price:</label>
    <input type="number" id="original_price" name="original_price" step="0.01">
  </div>

  <div class="input-group">
    <label for="discount">Discount:</label>
    <input type="number" id="discount" name="discount" step="0.01">
  </div>

  <!-- Inventory -->
  <div class="input-group">
    <label for="stock">Stock:</label>
    <input type="number" id="stock" name="stock" required>
  </div>

  <!-- Images -->
  <div class="input-group">
    <label for="image_url">Image URL:</label>
    <input type="text" id="image_url" name="image_url">
  </div>

  <div class="input-group">
    <label for="thumbnail_url">Thumbnail URL:</label>
    <input type="text" id="thumbnail_url" name="thumbnail_url">
  </div>

  <div class="input-group">
    <label for="alt_text">Alt Text:</label>
    <input type="text" id="alt_text" name="alt_text">
  </div>

  <!-- Category -->
  <div class="input-group">
    <label for="category_id">Category:</label>
    <select id="category_id" name="category_id">
      {{#each categories}}
        <option value="{{_id}}">{{name}}</option>
      {{/each}}
    </select>
  </div>

  <!-- Allowed Countries -->
  <div class="input-group">
    <label for="allowed_countries">Allowed Countries:</label>
    <input type="text" id="allowed_countries" name="allowed_countries">
  </div>

  <!-- Featured Product Checkbox -->
  <div class="input-group">
    <label>
      <input type="checkbox" id="is_featured" name="is_featured">
      Featured Product
    </label>
  </div>

  <!-- Status -->
  <div class="input-group">
    <label for="status">Status:</label>
    <select name="status" id="status">
      <option value="active">Active</option>
      <option value="inactive">Inactive</option>
      <option value="draft">Draft</option>
    </select>
  </div>

  <!-- Submit -->
  <div class="input-group">
    <button type="submit" class="btn btn-primary">Add Product</button>
    <a href="/products" class="btn">Cancel</a>
  </div>
</form>
