{{> header}}

<main class="container py-4">
  <h1>All Orders</h1>
  {{#if orders.length}}
    <table class="table">
      <thead>
        <tr>
          <th>#</th>
          <th>User</th>
          <th>Total</th>
          <th>Status</th>
          <th>Placed At</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#each orders}}
          <tr>
            <td>{{@index}}</td>
            <td>{{this.first_name}} {{this.last_name}}</td>
            <td>{{formatPrice this.total}}</td>
            <td>{{this.order_status}}</td>
            <td>{{formatDateTime this.createdAt}}</td>
            <td>
              <a href="/admin/orders/{{this._id}}" class="btn btn-sm btn-primary">Edit</a>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p>No orders found.</p>
  {{/if}}
</main>

{{> footer}}